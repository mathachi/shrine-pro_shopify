<section class="timeline" id="timeline-{{ section.id }}">
  <div class="timeline__container">

    {%- if section.settings.title != blank -%}
      <h2 class="timeline__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="timeline__track">

      <!-- Ligne de progression animée -->
      <div class="timeline__line">
        <div class="timeline__line-fill" id="timeline-fill-{{ section.id }}"></div>
      </div>

      {%- for block in section.blocks -%}
        <div class="timeline__step" data-step="{{ forloop.index }}" {{ block.shopify_attributes }}>

          <!-- Badge jour -->
          <div class="timeline__badge-wrap">
            <div class="timeline__badge">{{ block.settings.day_label }}</div>
          </div>

          <!-- Contenu -->
          <div class="timeline__content">
            <h3 class="timeline__step-title">{{ block.settings.step_title }}</h3>
            <p class="timeline__step-desc">{{ block.settings.step_desc }}</p>
          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

<style>
  #timeline-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #timeline-{{ section.id }} .timeline__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #timeline-{{ section.id }} .timeline__title {
    text-align: center;
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 56px;
    line-height: 1.2;
  }

  /* ══ TRACK (contient ligne + steps) ══ */
  #timeline-{{ section.id }} .timeline__track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Ligne verticale */
  #timeline-{{ section.id }} .timeline__line {
    position: absolute;
    left: 52px;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: {{ section.settings.line_inactive }};
    border-radius: 2px;
    overflow: hidden;
  }

  #timeline-{{ section.id }} .timeline__line-fill {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 0%;
    background: {{ section.settings.accent_color }};
    border-radius: 2px;
    transition: height 0.4s ease;
  }

  /* ══ ÉTAPE ══ */
  #timeline-{{ section.id }} .timeline__step {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 0 0 48px 0;
    opacity: 0.35;
    transition: opacity 0.5s ease;
  }

  #timeline-{{ section.id }} .timeline__step.is-active {
    opacity: 1;
  }

  #timeline-{{ section.id }} .timeline__step:last-child {
    padding-bottom: 0;
  }

  /* Badge */
  #timeline-{{ section.id }} .timeline__badge-wrap {
    flex-shrink: 0;
    width: 106px;
    display: flex;
    justify-content: flex-end;
  }

  #timeline-{{ section.id }} .timeline__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 14px;
    border-radius: 8px;
    border: 2px solid {{ section.settings.accent_color }};
    background: transparent;
    color: {{ section.settings.accent_color }};
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    transition: background 0.4s ease, color 0.4s ease;
    white-space: nowrap;
  }

  #timeline-{{ section.id }} .timeline__step.is-active .timeline__badge {
    background: {{ section.settings.accent_color }};
    color: #ffffff;
  }

  /* Contenu texte */
  #timeline-{{ section.id }} .timeline__content {
    flex: 1;
    padding-top: 4px;
  }

  #timeline-{{ section.id }} .timeline__step-title {
    font-size: clamp(16px, 1.6vw, 20px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 8px;
    line-height: 1.3;
    transition: color 0.4s ease;
  }

  #timeline-{{ section.id }} .timeline__step-desc {
    font-size: clamp(11px, 1vw, 13px);
    line-height: 1.6;
    color: {{ section.settings.desc_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ══ DESKTOP : timeline centrée avec contenu alternant ══ */
  @media (min-width: 769px) {
    #timeline-{{ section.id }} .timeline__container {
      max-width: 900px;
    }

    #timeline-{{ section.id }} .timeline__track {
      padding: 0 0 0 0;
    }

    /* Ligne centrée */
    #timeline-{{ section.id }} .timeline__line {
      left: 50%;
      transform: translateX(-50%);
      top: 20px;
      bottom: 20px;
    }

    /* Chaque step en 2 colonnes */
    #timeline-{{ section.id }} .timeline__step {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 32px;
      padding-bottom: 56px;
    }

    /* Badge au centre */
    #timeline-{{ section.id }} .timeline__badge-wrap {
      width: auto;
      justify-content: center;
      grid-column: 2;
    }

    /* Contenu à gauche pour les impairs, à droite pour les pairs */
    #timeline-{{ section.id }} .timeline__step:nth-child(odd) .timeline__content {
      grid-column: 1;
      grid-row: 1;
      text-align: right;
      order: -1;
    }

    #timeline-{{ section.id }} .timeline__step:nth-child(odd) .timeline__badge-wrap {
      grid-column: 2;
      grid-row: 1;
    }

    /* Colonne vide à droite pour les impairs */
    #timeline-{{ section.id }} .timeline__step:nth-child(odd)::after {
      content: '';
      grid-column: 3;
    }

    /* Colonne vide à gauche + contenu à droite pour les pairs */
    #timeline-{{ section.id }} .timeline__step:nth-child(even)::before {
      content: '';
      grid-column: 1;
    }

    #timeline-{{ section.id }} .timeline__step:nth-child(even) .timeline__content {
      grid-column: 3;
      grid-row: 1;
      text-align: left;
    }

    #timeline-{{ section.id }} .timeline__step:nth-child(even) .timeline__badge-wrap {
      grid-column: 2;
      grid-row: 1;
    }
  }

  @media (max-width: 768px) {
    #timeline-{{ section.id }} .timeline__container {
      padding: 0 20px;
    }
  }
</style>

<script>
(function() {
  const section = document.getElementById('timeline-{{ section.id }}');
  if (!section) return;

  const steps = section.querySelectorAll('.timeline__step');
  const fill = document.getElementById('timeline-fill-{{ section.id }}');
  const line = section.querySelector('.timeline__line');

  function getLineHeight() {
    if (!line) return 1;
    return line.offsetHeight || 1;
  }

  function updateTimeline() {
    let lastActiveIndex = -1;

    steps.forEach((step, i) => {
      const rect = step.getBoundingClientRect();
      const triggerPoint = window.innerHeight * 0.65;

      if (rect.top < triggerPoint) {
        step.classList.add('is-active');
        lastActiveIndex = i;
      } else {
        step.classList.remove('is-active');
      }
    });

    // Progression de la ligne
    if (fill && steps.length > 0) {
      if (lastActiveIndex < 0) {
        fill.style.height = '0%';
      } else if (lastActiveIndex >= steps.length - 1) {
        fill.style.height = '100%';
      } else {
        const pct = ((lastActiveIndex + 1) / steps.length) * 100;
        fill.style.height = pct + '%';
      }
    }
  }

  window.addEventListener('scroll', updateTimeline, { passive: true });
  updateTimeline();
})();
</script>

{% schema %}
{
  "name": "Timeline Résultats",
  "tag": "section",
  "class": "section-timeline",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre (optionnel)",
      "default": "Les résultats jour après jour"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accent (badge actif)",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "line_inactive",
      "label": "Couleur ligne inactive",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titres",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Couleur description",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0, "max": 120, "step": 4, "default": 64, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0, "max": 120, "step": 4, "default": 64, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        {
          "type": "text",
          "id": "day_label",
          "label": "Badge (ex: JOUR 30)",
          "default": "JOUR 30"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Titre de l'étape",
          "default": "Les premiers résultats sont visibles."
        },
        {
          "type": "textarea",
          "id": "step_desc",
          "label": "Description",
          "default": "La majorité de nos clientes constatent une amélioration visible en quelques semaines."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline Résultats",
      "blocks": [
        { "type": "step", "settings": { "day_label": "JOUR 7", "step_title": "La repousse ralentit perceptiblement.", "step_desc": "Les follicules pileux commencent à recevoir moins de stimulation enzymatique." } },
        { "type": "step", "settings": { "day_label": "JOUR 21", "step_title": "Les poils repoussent moins vite.", "step_desc": "80 % de nos clientes constatent un intervalle plus long entre deux épilations." } },
        { "type": "step", "settings": { "day_label": "JOUR 45", "step_title": "Les poils s'affinent visiblement.", "step_desc": "Le diamètre du poil diminue, la peau est plus douce et homogène." } },
        { "type": "step", "settings": { "day_label": "JOUR 90", "step_title": "Réduction durable confirmée.", "step_desc": "91 % des utilisatrices rapportent une réduction significative et durable de la repousse." } }
      ]
    }
  ]
}
{% endschema %}
