{% comment %}
  Section: Timeline Résultats (scroll active)
  Mobile: colonne (badge + texte + image)
  Desktop: badge au centre + texte alterné gauche/droite + image 1x1 optionnelle
{% endcomment %}

<section class="timeline" id="timeline-{{ section.id }}">
  <div class="timeline__container">

    {%- if section.settings.title != blank -%}
      <h2 class="timeline__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="timeline__track" id="timeline-track-{{ section.id }}">
      <div class="timeline__line" aria-hidden="true">
        <div class="timeline__line-fill" id="timeline-fill-{{ section.id }}"></div>
      </div>

      {%- for block in section.blocks -%}
        <article class="timeline__step" {{ block.shopify_attributes }}>
          <div class="timeline__badge-wrap">
            <div class="timeline__badge">{{ block.settings.day_label }}</div>
          </div>

          <div class="timeline__content">
            <h3 class="timeline__step-title">{{ block.settings.step_title }}</h3>
            <p class="timeline__step-desc">{{ block.settings.step_desc }}</p>

            {%- if block.settings.image != blank -%}
              <div class="timeline__img-wrap">
                <img
                  src="{{ block.settings.image | image_url: width: 700 }}"
                  alt="{{ block.settings.step_title | escape }}"
                  class="timeline__img"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}

    </div>
  </div>
</section>

<style>
  #timeline-{{ section.id }}{
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #timeline-{{ section.id }} .timeline__container{
    max-width: 980px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #timeline-{{ section.id }} .timeline__title{
    text-align: center;
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 800;
    color: {{ section.settings.title_color }};
    line-height: 1.15;
    margin: 0 0 52px;
  }

  #timeline-{{ section.id }} .timeline__track{
    position: relative;
  }

  /* =========
     BADGES (taille fixe)
  ========= */
  #timeline-{{ section.id }} .timeline__badge-wrap{
    width: var(--badge-w);
    flex: 0 0 var(--badge-w);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #timeline-{{ section.id }} .timeline__badge{
    width: var(--badge-w);
    height: var(--badge-h);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 2px solid {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
    background: transparent;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    white-space: nowrap;
    transition: background .35s ease, color .35s ease;
    box-sizing: border-box;
  }

  /* =========
     LIGNE EN TIRETS (au milieu des badges)
  ========= */
  #timeline-{{ section.id }} .timeline__line{
    position: absolute;
    left: calc(var(--pad-x) + (var(--badge-w) / 2) - 1px);
    top: calc(var(--badge-h) / 2);
    bottom: calc(var(--badge-h) / 2);
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      {{ section.settings.line_inactive }} 0px,
      {{ section.settings.line_inactive }} 7px,
      transparent 7px,
      transparent 14px
    );
    border-radius: 2px;
    overflow: hidden;
    pointer-events: none;
  }

  #timeline-{{ section.id }} .timeline__line-fill{
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background: repeating-linear-gradient(
      to bottom,
      {{ section.settings.accent_color }} 0px,
      {{ section.settings.accent_color }} 7px,
      transparent 7px,
      transparent 14px
    );
    transition: height .35s ease;
  }

  /* =========
     STEPS (mobile default)
  ========= */
  #timeline-{{ section.id }}{
    --badge-w: 92px;
    --badge-h: 38px;
    --pad-x: 20px; /* doit matcher .timeline__container padding horizontal */
  }

  #timeline-{{ section.id }} .timeline__step{
    display: flex;
    align-items: center;           /* centre badge vs ligne */
    gap: 22px;
    padding: 0 0 44px 0;
    opacity: .35;
    transition: opacity .35s ease;
  }

  #timeline-{{ section.id }} .timeline__step:last-child{
    padding-bottom: 0;
  }

  #timeline-{{ section.id }} .timeline__step.is-active{
    opacity: 1;
  }

  #timeline-{{ section.id }} .timeline__step.is-active .timeline__badge{
    background: {{ section.settings.accent_color }};
    color: #fff;
  }

  #timeline-{{ section.id }} .timeline__content{
    flex: 1;
    min-width: 0;
  }

  #timeline-{{ section.id }} .timeline__step-title{
    margin: 0 0 8px;
    font-size: clamp(16px, 1.7vw, 20px);
    font-weight: 800;
    color: {{ section.settings.title_color }};
    line-height: 1.25;
  }

  #timeline-{{ section.id }} .timeline__step-desc{
    margin: 0;
    font-size: clamp(11px, 1.1vw, 13px);
    line-height: 1.65;
    color: {{ section.settings.desc_color }};
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Image 1x1 optionnelle */
  #timeline-{{ section.id }} .timeline__img-wrap{
    margin-top: 14px;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    max-width: 280px;
    background: #eee;
  }

  #timeline-{{ section.id }} .timeline__img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* =========
     DESKTOP : badge au centre, contenu alterné
  ========= */
  @media (min-width: 769px){
    #timeline-{{ section.id }}{
      --pad-x: 20px;
    }

    #timeline-{{ section.id }} .timeline__container{
      padding: 0 20px;
    }

    #timeline-{{ section.id }} .timeline__line{
      left: 50%;
      transform: translateX(-50%);
      top: calc(var(--badge-h) / 2);
      bottom: calc(var(--badge-h) / 2);
    }

    #timeline-{{ section.id }} .timeline__step{
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 36px;
      align-items: center;
      padding-bottom: 56px;
    }

    #timeline-{{ section.id }} .timeline__badge-wrap{
      grid-column: 2;
    }

    /* Alternance texte gauche / droite */
    #timeline-{{ section.id }} .timeline__step:nth-child(odd) .timeline__content{
      grid-column: 1;
      text-align: right;
      justify-self: end;
      max-width: 420px;
    }

    #timeline-{{ section.id }} .timeline__step:nth-child(even) .timeline__content{
      grid-column: 3;
      text-align: left;
      justify-self: start;
      max-width: 420px;
    }

    #timeline-{{ section.id }} .timeline__img-wrap{
      max-width: 260px;
      margin-left: auto;
      margin-right: 0;
    }

    #timeline-{{ section.id }} .timeline__step:nth-child(even) .timeline__img-wrap{
      margin-left: 0;
      margin-right: auto;
    }
  }

  @media (max-width: 480px){
    #timeline-{{ section.id }}{
      --badge-w: 86px;
      --badge-h: 36px;
      --pad-x: 16px;
    }

    #timeline-{{ section.id }} .timeline__container{
      padding: 0 16px;
    }

    #timeline-{{ section.id }} .timeline__line{
      left: calc(var(--pad-x) + (var(--badge-w) / 2) - 1px);
    }

    #timeline-{{ section.id }} .timeline__img-wrap{
      max-width: 100%;
    }
  }
</style>

<script>
(function() {
  const root = document.getElementById('timeline-{{ section.id }}');
  if (!root) return;

  const steps = Array.from(root.querySelectorAll('.timeline__step'));
  const fill = root.querySelector('#timeline-fill-{{ section.id }}');
  if (!steps.length || !fill) return;

  function update() {
    let lastActive = -1;
    const trigger = window.innerHeight * 0.65;

    steps.forEach((el, i) => {
      const r = el.getBoundingClientRect();
      if (r.top < trigger) {
        el.classList.add('is-active');
        lastActive = i;
      } else {
        el.classList.remove('is-active');
      }
    });

    if (lastActive < 0) fill.style.height = '0%';
    else if (lastActive >= steps.length - 1) fill.style.height = '100%';
    else fill.style.height = (((lastActive + 1) / steps.length) * 100) + '%';
  }

  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
})();
</script>

{% schema %}
{
  "name": "Timeline Résultats",
  "tag": "section",
  "class": "section-timeline-results",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Les résultats jour après jour"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur accent",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "line_inactive",
      "label": "Couleur ligne inactive",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titres",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Couleur description",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        {
          "type": "text",
          "id": "day_label",
          "label": "Badge (ex: JOUR 30)",
          "default": "JOUR 30"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Titre",
          "default": "Les premiers résultats sont visibles."
        },
        {
          "type": "textarea",
          "id": "step_desc",
          "label": "Description",
          "default": "La majorité de nos clientes constatent une amélioration en quelques semaines."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optionnelle, 1:1)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline Résultats",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "day_label": "JOUR 7",
            "step_title": "La repousse ralentit.",
            "step_desc": "Les intervalles entre deux épilations s’allongent."
          }
        },
        {
          "type": "step",
          "settings": {
            "day_label": "JOUR 21",
            "step_title": "Moins de poils visibles.",
            "step_desc": "La peau paraît plus nette et plus douce."
          }
        },
        {
          "type": "step",
          "settings": {
            "day_label": "JOUR 45",
            "step_title": "Poils plus fins.",
            "step_desc": "La repousse est moins dense et moins épaisse."
          }
        }
      ]
    }
  ]
}
{% endschema %}
