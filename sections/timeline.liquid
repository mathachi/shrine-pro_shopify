{% comment %}
  Section: Timeline Résultats
  Layout: Ligne à gauche | Badge + Titre + Desc | Image 1x1 centrée
{% endcomment %}

<section class="tl" id="tl-{{ section.id }}">
  <div class="tl__container">

    {%- if section.settings.title != blank -%}
      <h2 class="tl__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="tl__track">
      <!-- Ligne verticale solide -->
      <div class="tl__line" aria-hidden="true">
        <div class="tl__line-fill" id="tl-fill-{{ section.id }}"></div>
      </div>

      {%- for block in section.blocks -%}
        <article class="tl__step" {{ block.shopify_attributes }}>

          <!-- Colonne gauche : badge + texte -->
          <div class="tl__left">
            <div class="tl__badge">{{ block.settings.day_label }}</div>
            <div class="tl__text">
              <h3 class="tl__step-title">{{ block.settings.step_title }}</h3>
              <p class="tl__step-desc">{{ block.settings.step_desc }}</p>
            </div>
          </div>

          <!-- Colonne droite : image optionnelle -->
          {%- if block.settings.image != blank -%}
            <div class="tl__right">
              <div class="tl__img-wrap">
                <img
                  src="{{ block.settings.image | image_url: width: 700 }}"
                  alt="{{ block.settings.step_title | escape }}"
                  class="tl__img"
                  loading="lazy"
                >
              </div>
            </div>
          {%- endif -%}

        </article>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  #tl-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #tl-{{ section.id }} .tl__container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #tl-{{ section.id }} .tl__title {
    text-align: center;
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 800;
    color: {{ section.settings.title_color }};
    line-height: 1.15;
    margin: 0 0 52px;
  }

  /* ══ TRACK ══ */
  #tl-{{ section.id }} .tl__track {
    position: relative;
    /* La ligne est alignée sur le centre des badges */
    padding-left: calc(var(--badge-w) / 2);
  }

  /* ══ LIGNE SOLIDE ══ */
  #tl-{{ section.id }} .tl__line {
    position: absolute;
    left: calc(var(--badge-w) / 2 - 1px);
    top: calc(var(--badge-h) / 2);
    bottom: calc(var(--badge-h) / 2);
    width: 2px;
    background: {{ section.settings.line_inactive }};
    border-radius: 2px;
    overflow: hidden;
    pointer-events: none;
  }

  #tl-{{ section.id }} .tl__line-fill {
    position: absolute;
    inset: 0 0 auto 0;
    height: 0%;
    background: {{ section.settings.accent_color }};
    transition: height .35s ease;
  }

  /* ══ STEP ══ */
  #tl-{{ section.id }} .tl__step {
    display: flex;
    align-items: center;
    gap: 32px;
    padding-bottom: 48px;
    margin-left: calc(var(--badge-w) / 2 * -1);
    opacity: .3;
    transition: opacity .4s ease;
  }

  #tl-{{ section.id }} .tl__step:last-child {
    padding-bottom: 0;
  }

  #tl-{{ section.id }} .tl__step.is-active {
    opacity: 1;
  }

  /* ══ COLONNE GAUCHE ══ */
  #tl-{{ section.id }} .tl__left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  /* Badge au-dessus du titre */
  #tl-{{ section.id }} .tl__badge {
    width: var(--badge-w);
    height: var(--badge-h);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 2px solid {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
    background: transparent;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background .35s ease, color .35s ease;
    box-sizing: border-box;
  }

  #tl-{{ section.id }} .tl__step.is-active .tl__badge {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }

  #tl-{{ section.id }} .tl__step-title {
    margin: 0 0 8px;
    font-size: clamp(17px, 1.8vw, 21px);
    font-weight: 800;
    color: {{ section.settings.title_color }};
    line-height: 1.25;
  }

  #tl-{{ section.id }} .tl__step-desc {
    margin: 0;
    font-size: clamp(11px, 1.1vw, 13px);
    line-height: 1.65;
    color: {{ section.settings.desc_color }};
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ══ COLONNE DROITE (image) ══ */
  #tl-{{ section.id }} .tl__right {
    flex-shrink: 0;
  }

  #tl-{{ section.id }} .tl__img-wrap {
    width: 180px;
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    background: #eee;
  }

  #tl-{{ section.id }} .tl__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ══ VARIABLES ══ */
  #tl-{{ section.id }} {
    --badge-w: 92px;
    --badge-h: 38px;
  }

  /* ══ MOBILE ══ */
  @media (max-width: 768px) {
    #tl-{{ section.id }} {
      --badge-w: 86px;
      --badge-h: 36px;
    }

    #tl-{{ section.id }} .tl__container {
      padding: 0 16px;
    }

    #tl-{{ section.id }} .tl__step {
      flex-direction: row;
      align-items: center;
      gap: 16px;
    }

    #tl-{{ section.id }} .tl__img-wrap {
      width: 110px;
    }

    #tl-{{ section.id }} .tl__step-title {
      font-size: 16px;
    }
  }
</style>

<script>
(function() {
  const root = document.getElementById('tl-{{ section.id }}');
  if (!root) return;

  const steps = Array.from(root.querySelectorAll('.tl__step'));
  const fill = root.querySelector('#tl-fill-{{ section.id }}');
  if (!steps.length || !fill) return;

  function update() {
    let lastActive = -1;
    const trigger = window.innerHeight * 0.68;

    steps.forEach((el, i) => {
      if (el.getBoundingClientRect().top < trigger) {
        el.classList.add('is-active');
        lastActive = i;
      } else {
        el.classList.remove('is-active');
      }
    });

    fill.style.height = lastActive < 0
      ? '0%'
      : lastActive >= steps.length - 1
        ? '100%'
        : (((lastActive + 1) / steps.length) * 100) + '%';
  }

  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);
  update();
})();
</script>

{% schema %}
{
  "name": "Timeline Résultats",
  "tag": "section",
  "class": "section-tl-results",
  "max_blocks": 8,
  "settings": [
    { "type": "text",  "id": "title",        "label": "Titre",               "default": "Les résultats jour après jour" },
    { "type": "color", "id": "accent_color", "label": "Couleur accent",      "default": "#2563eb" },
    { "type": "color", "id": "line_inactive","label": "Couleur ligne",       "default": "#d1d5db" },
    { "type": "color", "id": "bg_color",     "label": "Fond section",        "default": "#ffffff" },
    { "type": "color", "id": "title_color",  "label": "Couleur titres",      "default": "#111827" },
    { "type": "color", "id": "desc_color",   "label": "Couleur description", "default": "#6b7280" },
    { "type": "range", "id": "padding_top",  "label": "Padding haut", "min": 0, "max": 120, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom","label": "Padding bas",  "min": 0, "max": 120, "step": 4, "default": 64, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        { "type": "text",     "id": "day_label",  "label": "Badge (ex: JOUR 30)",  "default": "JOUR 30" },
        { "type": "text",     "id": "step_title", "label": "Titre",                "default": "Les premiers résultats sont visibles." },
        { "type": "textarea", "id": "step_desc",  "label": "Description",          "default": "La majorité de nos clientes constatent une amélioration en quelques semaines." },
        { "type": "image_picker", "id": "image",  "label": "Image 1:1 (optionnelle)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline Résultats",
      "blocks": [
        { "type": "step", "settings": { "day_label": "JOUR 7",  "step_title": "La repousse ralentit perceptiblement.", "step_desc": "Les follicules pileux commencent à recevoir moins de stimulation enzymatique." } },
        { "type": "step", "settings": { "day_label": "JOUR 21", "step_title": "Les poils repoussent moins vite.",       "step_desc": "80 % de nos clientes constatent un intervalle plus long entre deux épilations." } },
        { "type": "step", "settings": { "day_label": "JOUR 45", "step_title": "Les poils s'affinent visiblement.",     "step_desc": "Le diamètre du poil diminue, la peau est plus douce et homogène." } },
        { "type": "step", "settings": { "day_label": "JOUR 90", "step_title": "Réduction durable confirmée.",          "step_desc": "91 % des utilisatrices rapportent une réduction significative et durable." } }
      ]
    }
  ]
}
{% endschema %}
