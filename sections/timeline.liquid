<section class="tl" id="tl-{{ section.id }}">
  <div class="tl__container">

    {%- if section.settings.title != blank -%}
      <h2 class="tl__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <!-- Onglets -->
    <div class="tl__tabs" role="tablist">
      {%- for block in section.blocks -%}
        <button
          class="tl__tab{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          data-index="{{ forloop.index0 }}"
        >
          {{ block.settings.day_label }}
        </button>
      {%- endfor -%}
    </div>

    <!-- Panneaux -->
    <div class="tl__panels">
      {%- for block in section.blocks -%}
        <div
          class="tl__panel{% if forloop.first %} is-active{% endif %}"
          role="tabpanel"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <div class="tl__img-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.step_title | escape }}"
                class="tl__img"
                loading="lazy"
              >
            </div>
          {%- endif -%}

          <div class="tl__panel-content">
            <p class="tl__panel-label">{{ block.settings.day_label }}</p>
            <h3 class="tl__panel-title">{{ block.settings.step_title }}</h3>
            <p class="tl__panel-desc">{{ block.settings.step_desc }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>


<style>
  #tl-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #tl-{{ section.id }} .tl__container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #tl-{{ section.id }} .tl__title {
    text-align: center;
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 800;
    color: {{ section.settings.title_color }};
    line-height: 1.15;
    margin: 0 0 40px;
  }

  /* ══ ONGLETS ══ */
  #tl-{{ section.id }} .tl__tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  #tl-{{ section.id }} .tl__tab {
    padding: 9px 20px;
    border-radius: 999px;
    border: 2px solid {{ section.settings.accent_color }};
    background: transparent;
    color: {{ section.settings.accent_color }};
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease;
    white-space: nowrap;
  }

  #tl-{{ section.id }} .tl__tab:hover {
    background: {{ section.settings.accent_color }}22;
  }

  #tl-{{ section.id }} .tl__tab.is-active {
    background: {{ section.settings.accent_color }};
    color: #fff;
  }

  /* ══ PANNEAUX ══ */
  #tl-{{ section.id }} .tl__panels {
    position: relative;
  }

  #tl-{{ section.id }} .tl__panel {
    display: none;
    flex-direction: row;
    align-items: center;
    gap: 40px;
    animation: tl-fade 0.35s ease;
  }

  #tl-{{ section.id }} .tl__panel.is-active {
    display: flex;
  }

  @keyframes tl-fade {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #tl-{{ section.id }} .tl__img-wrap {
    flex: 0 0 45%;
    aspect-ratio: 1 / 1;
    border-radius: 18px;
    overflow: hidden;
    background: #eee;
  }

  #tl-{{ section.id }} .tl__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #tl-{{ section.id }} .tl__panel-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #tl-{{ section.id }} .tl__panel-label {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0;
  }

  #tl-{{ section.id }} .tl__panel-title {
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 800;
    color: {{ section.settings.title_color }};
    line-height: 1.25;
    margin: 0;
  }

  #tl-{{ section.id }} .tl__panel-desc {
    font-size: clamp(13px, 1.1vw, 15px);
    line-height: 1.7;
    color: {{ section.settings.desc_color }};
    margin: 0;
  }

  /* ══ MOBILE ══ */
  @media (max-width: 640px) {
    #tl-{{ section.id }} .tl__container {
      padding: 0 16px;
    }

    #tl-{{ section.id }} .tl__tabs {
      gap: 8px;
    }

    #tl-{{ section.id }} .tl__tab {
      font-size: 12px;
      padding: 7px 14px;
    }

    #tl-{{ section.id }} .tl__panel {
      flex-direction: column;
      gap: 20px;
    }

    #tl-{{ section.id }} .tl__img-wrap {
      flex: none;
      width: 100%;
    }
  }
</style>


<script>
(function() {
  const root = document.getElementById('tl-{{ section.id }}');
  if (!root) return;

  const tabs   = Array.from(root.querySelectorAll('.tl__tab'));
  const panels = Array.from(root.querySelectorAll('.tl__panel'));

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const idx = tab.dataset.index;

      tabs.forEach(t => {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('is-active'));

      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      const panel = panels.find(p => p.dataset.index === idx);
      if (panel) panel.classList.add('is-active');
    });
  });
})();
</script>


{% schema %}
{
  "name": "Timeline Résultats",
  "tag": "section",
  "class": "section-tl-results",
  "max_blocks": 12,
  "settings": [
    { "type": "text",  "id": "title",          "label": "Titre",               "default": "Les résultats jour après jour" },
    { "type": "color", "id": "accent_color",   "label": "Couleur accent",      "default": "#2563eb" },
    { "type": "color", "id": "bg_color",       "label": "Fond section",        "default": "#ffffff" },
    { "type": "color", "id": "title_color",    "label": "Couleur titres",      "default": "#111827" },
    { "type": "color", "id": "desc_color",     "label": "Couleur description", "default": "#6b7280" },
    { "type": "range", "id": "padding_top",    "label": "Padding haut",  "min": 0, "max": 120, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bas",   "min": 0, "max": 120, "step": 4, "default": 64, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        { "type": "text",         "id": "day_label",  "label": "Badge (ex : JOUR 30)" },
        { "type": "text",         "id": "step_title", "label": "Titre" },
        { "type": "textarea",     "id": "step_desc",  "label": "Description" },
        { "type": "image_picker", "id": "image",      "label": "Image (optionnelle)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline Résultats",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}