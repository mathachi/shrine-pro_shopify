<section class="ingredients" id="ingredients-{{ section.id }}">
  <div class="ingredients__header">
    <h2 class="ingredients__title">{{ section.settings.title }}</h2>
  </div>

  <div class="ingredients__carousel-wrap">
    <button class="ingredients__arrow ingredients__arrow--prev" aria-label="Précédent">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <div class="ingredients__grid">
      {%- for block in section.blocks -%}
        <div class="ingredients__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.name }}"
              class="ingredients__card-img"
              loading="lazy"
              draggable="false"
            >
          {%- else -%}
            <div class="ingredients__card-placeholder"></div>
          {%- endif -%}
          <div class="ingredients__card-overlay"></div>
          <div class="ingredients__card-content">
            <h3 class="ingredients__card-name">{{ block.settings.name }}</h3>
            <p class="ingredients__card-desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <button class="ingredients__arrow ingredients__arrow--next" aria-label="Suivant">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

  <p class="ingredients__scroll-hint">→ Faire défiler →</p>
</section>


<style>
  #ingredients-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #ingredients-{{ section.id }} .ingredients__header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #ingredients-{{ section.id }} .ingredients__title {
    text-align: center;
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 40px;
    line-height: 1.2;
  }

  /* ══ DESKTOP ══ */
  #ingredients-{{ section.id }} .ingredients__carousel-wrap {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 24px;
  }

  #ingredients-{{ section.id }} .ingredients__grid {
    flex: 1;
    display: flex;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 16px;
    box-sizing: border-box;
    padding: 0;
  }

  #ingredients-{{ section.id }} .ingredients__grid::-webkit-scrollbar {
    display: none;
  }

  #ingredients-{{ section.id }} .ingredients__card {
    position: relative;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    flex: 0 0 calc((100% - 2 * 16px) / 2.8);
    aspect-ratio: 1 / 1;
    scroll-snap-align: start;
    cursor: default;
    isolation: isolate;
  }

  #ingredients-{{ section.id }} .ingredients__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
    transition: transform 0.5s ease;
  }

  #ingredients-{{ section.id }} .ingredients__card:hover .ingredients__card-img {
    transform: scale(1.04);
  }

  #ingredients-{{ section.id }} .ingredients__card-placeholder {
    position: absolute;
    inset: 0;
    background: #d5cfc7;
    z-index: 0;
  }

  #ingredients-{{ section.id }} .ingredients__card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px;
    z-index: 2;
  }

  #ingredients-{{ section.id }} .ingredients__card-name {
    font-size: clamp(18px, 1.6vw, 22px);
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 10px;
    line-height: 1.2;
  }

  #ingredients-{{ section.id }} .ingredients__card-desc {
    font-size: clamp(12px, 1vw, 14px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    margin: 0;
  }

  #ingredients-{{ section.id }} .ingredients__arrow {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid rgba(0, 0, 0, 0.15);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #333;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.10);
  }

  #ingredients-{{ section.id }} .ingredients__arrow:hover {
    background: #f5f5f5;
    border-color: rgba(0, 0, 0, 0.3);
    transform: scale(1.05);
  }

  #ingredients-{{ section.id }} .ingredients__scroll-hint {
    display: none;
  }

  /* ══ MOBILE ══ */
  @media (max-width: 768px) {
    #ingredients-{{ section.id }} .ingredients__arrow {
      display: none;
    }

    #ingredients-{{ section.id }} .ingredients__carousel-wrap {
      padding: 0;
    }

    #ingredients-{{ section.id }} .ingredients__grid {
      padding: 0 16px;
      scroll-padding-left: 16px;
      gap: 12px;
      max-width: 100%;
    }

    #ingredients-{{ section.id }} .ingredients__card {
      flex: 0 0 calc(100vw - 64px);
      width: calc(100vw - 64px);
    }

    #ingredients-{{ section.id }} .ingredients__title {
      font-size: 24px;
      margin-bottom: 28px;
    }

    #ingredients-{{ section.id }} .ingredients__card-content {
      padding: 20px 16px;
    }

    #ingredients-{{ section.id }} .ingredients__card-name {
      font-size: 20px;
    }

    #ingredients-{{ section.id }} .ingredients__card-desc {
      font-size: 13px;
    }

    #ingredients-{{ section.id }} .ingredients__scroll-hint {
      display: block;
      text-align: center;
      font-size: 13px;
      color: {{ section.settings.hint_color }};
      margin-top: 16px;
      letter-spacing: 0.02em;
    }
  }
</style>

<script>
  (function() {
    const section = document.getElementById('ingredients-{{ section.id }}');
    if (!section) return;

    const grid    = section.querySelector('.ingredients__grid');
    const btnPrev = section.querySelector('.ingredients__arrow--prev');
    const btnNext = section.querySelector('.ingredients__arrow--next');
    if (!grid || !btnPrev || !btnNext) return;

    function getScrollAmount() {
      const card = grid.querySelector('.ingredients__card');
      return card ? card.offsetWidth + 16 : 300;
    }

    btnPrev.addEventListener('click', () => {
      grid.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    btnNext.addEventListener('click', () => {
      grid.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  })();
</script>

{% schema %}
{
  "name": "Ingrédients",
  "tag": "section",
  "class": "section-ingredients",
  "max_blocks": 50,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Ingrédients testés cliniquement"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#f5f0eb"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "hint_color",
      "label": "Couleur texte 'Faire défiler' (mobile)",
      "default": "#888888"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingrédient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo de l'ingrédient"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom de l'ingrédient"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingrédients",
      "blocks": []
    }
  ]
}
{% endschema %}