<section class="testimonials-carousel" id="testimonials-{{ section.id }}">
  <div class="testimonials-carousel__container">

    <!-- En-tête -->
    {%- if section.settings.badge != blank -%}
      <div class="testimonials-carousel__badge-wrap">
        <span class="testimonials-carousel__badge">{{ section.settings.badge }}</span>
      </div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="testimonials-carousel__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <!-- Carousel wrapper -->
    <div class="testimonials-carousel__outer">
      <button class="testimonials-carousel__arrow testimonials-carousel__arrow--prev" aria-label="Précédent">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="testimonials-carousel__track-wrap">
        <div class="testimonials-carousel__track">
          {%- for block in section.blocks -%}
            <div class="testimonials-carousel__card" {{ block.shopify_attributes }}>

              {%- if block.settings.image != blank -%}
                <div class="testimonials-carousel__card-img">
                  <img
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="Avis client"
                    loading="lazy"
                  >
                </div>
              {%- endif -%}

              <div class="testimonials-carousel__card-body">
                <div class="testimonials-carousel__verified">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#22c55e"/><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{{ section.settings.verified_label | default: "Verified customer" }}</span>
                </div>

                <p class="testimonials-carousel__review">{{ block.settings.review }}</p>

                <div class="testimonials-carousel__author">
                  <div class="testimonials-carousel__author-left">
                    {%- if block.settings.avatar != blank -%}
                      <img
                        class="testimonials-carousel__avatar"
                        src="{{ block.settings.avatar | image_url: width: 80 }}"
                        alt="{{ block.settings.name }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      <div class="testimonials-carousel__avatar-initial">
                        {{ block.settings.name | slice: 0 }}
                      </div>
                    {%- endif -%}
                    <div>
                      <div class="testimonials-carousel__name">{{ block.settings.name }}</div>
                      <div class="testimonials-carousel__stars">
                        {%- assign rating = block.settings.rating | default: 5 -%}
                        {%- for i in (1..5) -%}
                          {%- if i <= rating -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                          {%- else -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="#e5e7eb"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          {%- endfor -%}
        </div>
      </div>

      <button class="testimonials-carousel__arrow testimonials-carousel__arrow--next" aria-label="Suivant">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <!-- Dots -->
    <div class="testimonials-carousel__dots"></div>

  </div>
</section>

<style>
  #testimonials-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .testimonials-carousel__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .testimonials-carousel__badge-wrap {
    text-align: center;
    margin-bottom: 12px;
  }

  .testimonials-carousel__badge {
    display: inline-block;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 999px;
    border: 1px solid {{ section.settings.badge_color }}33;
  }

  .testimonials-carousel__title {
    text-align: center;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 40px;
    line-height: 1.25;
  }

  .testimonials-carousel__outer {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonials-carousel__track-wrap {
    overflow: hidden;
    flex: 1;
  }

  .testimonials-carousel__track {
    display: flex;
    gap: 20px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    align-items: stretch;
  }

  .testimonials-carousel__card {
    flex: 0 0 calc(25% - 15px);
    background: {{ section.settings.card_bg }};
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonials-carousel__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .testimonials-carousel__card-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .testimonials-carousel__card-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .testimonials-carousel__card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .testimonials-carousel__verified {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: #374151;
  }

  .testimonials-carousel__review {
    font-size: 13px;
    line-height: 1.6;
    color: #4b5563;
    margin: 0;
    flex: 1;
  }

  .testimonials-carousel__author {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .testimonials-carousel__author-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testimonials-carousel__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonials-carousel__avatar-initial {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: {{ section.settings.badge_color }};
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  .testimonials-carousel__name {
    font-size: 13px;
    font-weight: 600;
    color: #111827;
  }

  .testimonials-carousel__stars {
    display: flex;
    gap: 2px;
    margin-top: 2px;
  }

  /* Arrows */
  .testimonials-carousel__arrow {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1.5px solid #d1d5db;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #374151;
    transition: background 0.2s, border-color 0.2s;
    z-index: 2;
  }

  .testimonials-carousel__arrow:hover {
    background: #f3f4f6;
    border-color: #9ca3af;
  }

  /* Dots */
  .testimonials-carousel__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .testimonials-carousel__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d1d5db;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    border: none;
    padding: 0;
  }

  .testimonials-carousel__dot.is-active {
    background: {{ section.settings.badge_color }};
    transform: scale(1.2);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .testimonials-carousel__arrow {
      display: none;
    }

    .testimonials-carousel__card {
      flex: 0 0 80%;
    }

    .testimonials-carousel__track-wrap {
      cursor: grab;
    }
  }

  @media (max-width: 480px) {
    .testimonials-carousel__card {
      flex: 0 0 88%;
    }
  }
</style>

<script>
(function() {
  const section = document.getElementById('testimonials-{{ section.id }}');
  if (!section) return;

  const track      = section.querySelector('.testimonials-carousel__track');
  const wrap       = section.querySelector('.testimonials-carousel__track-wrap');
  const btnPrev    = section.querySelector('.testimonials-carousel__arrow--prev');
  const btnNext    = section.querySelector('.testimonials-carousel__arrow--next');
  const dotsWrap   = section.querySelector('.testimonials-carousel__dots');
  const VISIBLE_DT = {{ section.settings.visible_cards }};
  const GAP        = 20;

  const originals = Array.from(track.querySelectorAll('.testimonials-carousel__card'));
  const total     = originals.length;
  if (!total) return;

  let current         = 0;
  let isTransitioning = false;
  let touchStartX     = 0;
  let touchStartY     = 0;
  let touchDir        = null; // 'h' | 'v' | null

  /* ── Responsive ── */
  function getVisible() {
    if (window.innerWidth <= 480) return 1;
    if (window.innerWidth <= 768) return 1;
    return VISIBLE_DT;
  }

  /* ── Largeur des cartes calculée en JS ── */
  function setWidths() {
    const vis     = getVisible();
    const w       = (wrap.offsetWidth - GAP * (vis - 1)) / vis;
    track.querySelectorAll('.testimonials-carousel__card').forEach(c => {
      c.style.flex  = `0 0 ${w}px`;
      c.style.width = `${w}px`;
    });
  }

  function step() {
    const c = track.querySelector('.testimonials-carousel__card');
    return c ? c.offsetWidth + GAP : 0;
  }

  /* ── Clones pour boucle infinie ── */
  function setupClones() {
    track.querySelectorAll('.tc-clone').forEach(el => el.remove());

    // Prépend (ordre inversé pour que insertBefore donne le bon ordre)
    [...originals].reverse().forEach(card => {
      const cl = card.cloneNode(true);
      cl.classList.add('tc-clone');
      cl.setAttribute('aria-hidden', 'true');
      track.insertBefore(cl, track.firstChild);
    });
    // Append
    originals.forEach(card => {
      const cl = card.cloneNode(true);
      cl.classList.add('tc-clone');
      cl.setAttribute('aria-hidden', 'true');
      track.appendChild(cl);
    });
  }

  /* ── Navigation ── */
  function goTo(idx, animate = true) {
    current = idx;
    const pos = (total + idx) * step();
    track.style.transition = animate
      ? 'transform 0.4s cubic-bezier(0.4,0,0.2,1)'
      : 'none';
    track.style.transform = `translateX(-${pos}px)`;
    if (!animate) track.offsetHeight; // force reflow
    updateDots();
  }

  track.addEventListener('transitionend', () => {
    // Saut silencieux pour la boucle infinie
    if (current < 0)      goTo(total + current, false);
    else if (current >= total) goTo(current - total, false);
    isTransitioning = false;
  });

  function prev() {
    if (isTransitioning) return;
    isTransitioning = true;
    goTo(current - 1);
  }

  function next() {
    if (isTransitioning) return;
    isTransitioning = true;
    goTo(current + 1);
  }

  btnPrev.addEventListener('click', prev);
  btnNext.addEventListener('click', next);

  /* ── Dots ── */
  function buildDots() {
    dotsWrap.innerHTML = '';
    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = 'testimonials-carousel__dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.addEventListener('click', () => {
        if (isTransitioning) return;
        isTransitioning = true;
        goTo(i);
      });
      dotsWrap.appendChild(dot);
    }
  }

  function updateDots() {
    const norm = ((current % total) + total) % total;
    dotsWrap.querySelectorAll('.testimonials-carousel__dot').forEach((d, i) => {
      d.classList.toggle('is-active', i === norm);
    });
  }

  /* ── Touch : verrouillage directionnel ── */
  wrap.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    touchDir    = null;
  }, { passive: true });

  wrap.addEventListener('touchmove', e => {
    const dx = Math.abs(e.touches[0].clientX - touchStartX);
    const dy = Math.abs(e.touches[0].clientY - touchStartY);

    if (!touchDir && (dx > 5 || dy > 5)) {
      touchDir = dx >= dy ? 'h' : 'v';
    }

    // Si scroll horizontal → bloque le scroll vertical du navigateur
    if (touchDir === 'h') e.preventDefault();
  }, { passive: false }); // passive:false obligatoire pour preventDefault

  wrap.addEventListener('touchend', e => {
    if (touchDir !== 'h') return;
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) diff > 0 ? next() : prev();
    touchDir = null;
  });

  /* ── Resize ── */
  window.addEventListener('resize', () => {
    setupClones();
    setWidths();
    goTo(current, false);
  });

  /* ── Init ── */
  requestAnimationFrame(() => {
    setupClones();
    setWidths();
    buildDots();
    goTo(0, false);
  });
})();
</script>

{% schema %}
{
  "name": "Testimonials Carousel",
  "tag": "section",
  "class": "section-testimonials-carousel",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Our Testimonials"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Our customers tell it better than we do!"
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Label vérifié",
      "default": "Verified customer"
    },
    {
      "type": "range",
      "id": "visible_cards",
      "label": "Cartes visibles (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond carte",
      "default": "#f0f7f5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titre",
      "default": "#1a3a33"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Fond badge",
      "default": "#e6f2ef"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Couleur badge / accent",
      "default": "#1a8a6f"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo principale"
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Texte du témoignage",
          "default": "Ce produit a changé ma routine, je le recommande à toutes mes amies !"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom du client",
          "default": "Marie L."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Note (étoiles)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Carousel",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
