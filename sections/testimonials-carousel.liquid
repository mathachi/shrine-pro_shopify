<section class="testimonials-carousel" id="testimonials-{{ section.id }}">
  <div class="testimonials-carousel__container">

    <!-- En-tête -->
    {%- if section.settings.badge != blank -%}
      <div class="testimonials-carousel__badge-wrap">
        <span class="testimonials-carousel__badge">{{ section.settings.badge }}</span>
      </div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="testimonials-carousel__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <!-- Carousel wrapper -->
    <div class="testimonials-carousel__outer">
      <button class="testimonials-carousel__arrow testimonials-carousel__arrow--prev" aria-label="Précédent">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="testimonials-carousel__track-wrap">
        <div class="testimonials-carousel__track">
          {%- for block in section.blocks -%}
            <div class="testimonials-carousel__card" {{ block.shopify_attributes }}>

              {%- if block.settings.image != blank -%}
                <div class="testimonials-carousel__card-img">
                  <img
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="Avis client"
                    loading="lazy"
                  >
                </div>
              {%- endif -%}

              <div class="testimonials-carousel__card-body">
                <div class="testimonials-carousel__verified">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#22c55e"/><path d="M7 12.5l3.5 3.5 6.5-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span>{{ section.settings.verified_label | default: "Verified customer" }}</span>
                </div>

                <p class="testimonials-carousel__review">{{ block.settings.review }}</p>

                <div class="testimonials-carousel__author">
                  <div class="testimonials-carousel__author-left">
                    {%- if block.settings.avatar != blank -%}
                      <img
                        class="testimonials-carousel__avatar"
                        src="{{ block.settings.avatar | image_url: width: 80 }}"
                        alt="{{ block.settings.name }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      <div class="testimonials-carousel__avatar-initial">
                        {{ block.settings.name | slice: 0 }}
                      </div>
                    {%- endif -%}
                    <div>
                      <div class="testimonials-carousel__name">{{ block.settings.name }}</div>
                      <div class="testimonials-carousel__stars">
                        {%- assign rating = block.settings.rating | default: 5 -%}
                        {%- for i in (1..5) -%}
                          {%- if i <= rating -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                          {%- else -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="#e5e7eb"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          {%- endfor -%}
        </div>
      </div>

      <button class="testimonials-carousel__arrow testimonials-carousel__arrow--next" aria-label="Suivant">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <!-- Dots -->
    <div class="testimonials-carousel__dots"></div>

  </div>
</section>

<style>
  #testimonials-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .testimonials-carousel__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .testimonials-carousel__badge-wrap {
    text-align: center;
    margin-bottom: 12px;
  }

  .testimonials-carousel__badge {
    display: inline-block;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    font-size: 13px;
    font-weight: 500;
    padding: 5px 16px;
    border-radius: 999px;
    border: 1px solid {{ section.settings.badge_color }}33;
  }

  .testimonials-carousel__title {
    text-align: center;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 40px;
    line-height: 1.25;
  }

  .testimonials-carousel__outer {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonials-carousel__track-wrap {
    overflow: hidden;
    flex: 1;
  }

  .testimonials-carousel__track {
    display: flex;
    gap: 20px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    align-items: stretch;
  }

  .testimonials-carousel__card {
    flex: 0 0 calc(25% - 15px);
    background: {{ section.settings.card_bg }};
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonials-carousel__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .testimonials-carousel__card-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .testimonials-carousel__card-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .testimonials-carousel__card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .testimonials-carousel__verified {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: #374151;
  }

  .testimonials-carousel__review {
    font-size: 13px;
    line-height: 1.6;
    color: #4b5563;
    margin: 0;
    flex: 1;
  }

  .testimonials-carousel__author {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .testimonials-carousel__author-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testimonials-carousel__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonials-carousel__avatar-initial {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: {{ section.settings.badge_color }};
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  .testimonials-carousel__name {
    font-size: 13px;
    font-weight: 600;
    color: #111827;
  }

  .testimonials-carousel__stars {
    display: flex;
    gap: 2px;
    margin-top: 2px;
  }

  /* Arrows */
  .testimonials-carousel__arrow {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1.5px solid #d1d5db;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #374151;
    transition: background 0.2s, border-color 0.2s;
    z-index: 2;
  }

  .testimonials-carousel__arrow:hover {
    background: #f3f4f6;
    border-color: #9ca3af;
  }

  /* Dots */
  .testimonials-carousel__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .testimonials-carousel__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d1d5db;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    border: none;
    padding: 0;
  }

  .testimonials-carousel__dot.is-active {
    background: {{ section.settings.badge_color }};
    transform: scale(1.2);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .testimonials-carousel__arrow {
      display: none;
    }

    .testimonials-carousel__card {
      flex: 0 0 80%;
    }

    .testimonials-carousel__track-wrap {
      cursor: grab;
    }
  }

  @media (max-width: 480px) {
    .testimonials-carousel__card {
      flex: 0 0 88%;
    }
  }
</style>

<script>
  (function() {
    const section = document.getElementById('testimonials-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('.testimonials-carousel__track');
    const cards = section.querySelectorAll('.testimonials-carousel__card');
    const btnPrev = section.querySelector('.testimonials-carousel__arrow--prev');
    const btnNext = section.querySelector('.testimonials-carousel__arrow--next');
    const dotsContainer = section.querySelector('.testimonials-carousel__dots');

    const visibleDesktop = {{ section.settings.visible_cards }};
    let current = 0;
    let isDragging = false;
    let startX = 0;
    let scrollStart = 0;

    function getVisible() {
      return window.innerWidth <= 480 ? 1 : window.innerWidth <= 768 ? 1 : visibleDesktop;
    }

    function maxIndex() {
      return Math.max(0, cards.length - getVisible());
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      const total = maxIndex() + 1;
      for (let i = 0; i < total; i++) {
        const dot = document.createElement('button');
        dot.className = 'testimonials-carousel__dot' + (i === current ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Slide ' + (i + 1));
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      dotsContainer.querySelectorAll('.testimonials-carousel__dot').forEach((d, i) => {
        d.classList.toggle('is-active', i === current);
      });
    }

    function goTo(index) {
      current = Math.max(0, Math.min(index, maxIndex()));
      const cardWidth = cards[0].offsetWidth + 20;
      track.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
      updateDots();
    }

    btnPrev.addEventListener('click', () => goTo(current - 1));
    btnNext.addEventListener('click', () => goTo(current + 1));

    // Swipe touch
    const wrap = section.querySelector('.testimonials-carousel__track-wrap');
    wrap.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
    wrap.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? goTo(current + 1) : goTo(current - 1);
    });

    // Mouse drag
    wrap.addEventListener('mousedown', e => { isDragging = true; startX = e.clientX; wrap.style.cursor = 'grabbing'; });
    window.addEventListener('mouseup', e => {
      if (!isDragging) return;
      const diff = startX - e.clientX;
      if (Math.abs(diff) > 50) diff > 0 ? goTo(current + 1) : goTo(current - 1);
      isDragging = false;
      wrap.style.cursor = 'grab';
    });

    window.addEventListener('resize', () => { buildDots(); goTo(current); });

    buildDots();
    goTo(0);
  })();
</script>

{% schema %}
{
  "name": "Testimonials Carousel",
  "tag": "section",
  "class": "section-testimonials-carousel",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Our Testimonials"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Our customers tell it better than we do!"
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Label vérifié",
      "default": "Verified customer"
    },
    {
      "type": "range",
      "id": "visible_cards",
      "label": "Cartes visibles (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond carte",
      "default": "#f0f7f5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titre",
      "default": "#1a3a33"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Fond badge",
      "default": "#e6f2ef"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Couleur badge / accent",
      "default": "#1a8a6f"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo principale"
        },
        {
          "type": "textarea",
          "id": "review",
          "label": "Texte du témoignage",
          "default": "Ce produit a changé ma routine, je le recommande à toutes mes amies !"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom du client",
          "default": "Marie L."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Note (étoiles)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Carousel",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
