<section class="ugc-gallery" id="ugc-gallery-{{ section.id }}">
  <div class="ugc-gallery__container">

    <h2 class="ugc-gallery__title">{{ section.settings.title }}</h2>

    <div class="ugc-gallery__grid">
      {%- for block in section.blocks -%}
        <div class="ugc-gallery__item" {{ block.shopify_attributes }}>

          <div class="ugc-gallery__media-wrapper">
            {%- if block.settings.video_url != blank -%}
              <video
                autoplay
                loop
                muted
                playsinline
                preload="auto"
                class="ugc-gallery__video"
              >
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- elsif block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="ugc-gallery__image"
                loading="lazy"
              >
            {%- endif -%}

            {%- if block.settings.overlay_text != blank -%}
              <div class="ugc-gallery__overlay">
                <span class="ugc-gallery__overlay-text">{{ block.settings.overlay_text }}</span>
              </div>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  #ugc-gallery-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .ugc-gallery__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ugc-gallery__title {
    text-align: center;
    font-size: clamp(20px, 2.5vw, 30px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 40px;
    line-height: 1.3;
  }

  .ugc-gallery__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  .ugc-gallery__media-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    background: #d9d0c7;
  }

  .ugc-gallery__video,
  .ugc-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Overlay texte style "post-it" */
  .ugc-gallery__overlay {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    z-index: 2;
    pointer-events: none;
  }

  .ugc-gallery__overlay-text {
    display: inline-block;
    background: #ffffff;
    color: #1a1a1a;
    font-size: clamp(11px, 1vw, 14px);
    font-weight: 600;
    line-height: 1.35;
    padding: 8px 12px;
    border-radius: 4px;
    text-align: center;
    max-width: 160px;
    box-shadow: 1px 2px 6px rgba(0,0,0,0.18);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .ugc-gallery__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 12px;
    }

    .ugc-gallery__title {
      font-size: 22px;
      margin-bottom: 24px;
    }

    .ugc-gallery__overlay-text {
      font-size: 10px;
      max-width: 110px;
      padding: 6px 8px;
    }
  }
</style>

{% schema %}
{
  "name": "UGC Galerie Vidéos",
  "tag": "section",
  "class": "section-ugc-gallery",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Plus de 150 000 femmes l'ont adopté, et vous ?"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colonnes (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Colonnes (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement entre vidéos",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#f5f0eb"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Vidéo UGC",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "URL de la vidéo (.mp4)",
          "info": "Contenu > Fichiers > copier l'URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de fallback"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Texte overlay (optionnel)",
          "info": "Ex: \"Ma peau s'est tellement rajeunie je recommande !\""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Galerie Vidéos",
      "blocks": [
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" }
      ]
    }
  ]
}
{% endschema %}
