<section class="ugc-gallery" id="ugc-gallery-{{ section.id }}">
  <div class="ugc-gallery__header">
    <h2 class="ugc-gallery__title">{{ section.settings.title }}</h2>
  </div>

  <div class="ugc-gallery__track-wrap">
    <div class="ugc-gallery__track">
      {%- for block in section.blocks -%}
        <div class="ugc-gallery__item" {{ block.shopify_attributes }}>
          <div class="ugc-gallery__media-wrapper">
            {%- if block.settings.video_url != blank -%}
              <video autoplay loop muted playsinline preload="auto" class="ugc-gallery__video">
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- elsif block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="ugc-gallery__image"
                loading="lazy"
                draggable="false"
              >
            {%- endif -%}

            {%- if block.settings.overlay_text != blank -%}
              <div class="ugc-gallery__overlay">
                <span class="ugc-gallery__overlay-text">{{ block.settings.overlay_text }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #ugc-gallery-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__title {
    text-align: center;
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 36px;
    line-height: 1.25;
  }

  /* ══════════════════════════════
     DESKTOP : centré, pas de scroll
  ══════════════════════════════ */
  #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    overflow: hidden;
    cursor: default;
    box-sizing: border-box;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__track {
    display: flex;
    gap: 14px;
    justify-content: center;
    align-items: stretch;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__item {
    flex-shrink: 0;
    width: 240px;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__media-wrapper {
    position: relative;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    background: #d9d0c7;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__video,
  #ugc-gallery-{{ section.id }} .ugc-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__overlay {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    z-index: 2;
    pointer-events: none;
    width: 85%;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__overlay-text {
    display: inline-block;
    background: #ffffff;
    color: #1a1a1a;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.35;
    padding: 8px 12px;
    border-radius: 6px;
    text-align: center;
    max-width: 100%;
    box-shadow: 1px 2px 8px rgba(0,0,0,0.2);
  }

  /* ══════════════════════════════
     MOBILE : scroll snap
  ══════════════════════════════ */
  @media (max-width: 768px) {
    #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap {
      max-width: 100%;
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding: 0 16px;
      scroll-padding-left: 16px;
      cursor: grab;
    }

    #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap:active {
      cursor: grabbing;
    }

    #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap::-webkit-scrollbar {
      display: none;
    }

    #ugc-gallery-{{ section.id }} .ugc-gallery__track {
      width: max-content;
      justify-content: flex-start;
      gap: 12px;
    }

    /* 1 carte = 72% → la 2e dépasse d'environ 20% (hint visuel) */
    #ugc-gallery-{{ section.id }} .ugc-gallery__item {
      scroll-snap-align: start;
      width: calc((100vw - 32px) * 0.72);
    }

    #ugc-gallery-{{ section.id }} .ugc-gallery__title {
      font-size: 20px;
      margin-bottom: 20px;
    }
  }
</style>

<script>
(function() {
  const section = document.querySelector('#ugc-gallery-{{ section.id }}');
  if (!section) return;

  const wrap = section.querySelector('.ugc-gallery__track-wrap');
  const track = section.querySelector('.ugc-gallery__track');
  if (!wrap || !track) return;

  // Mouse drag (desktop)
  let isDown = false;
  let startX = 0;
  let scrollLeft = 0;

  wrap.addEventListener('mousedown', e => {
    if (window.innerWidth <= 768) return;
    isDown = true;
    startX = e.pageX - wrap.offsetLeft;
    scrollLeft = wrap.scrollLeft;
    wrap.style.scrollSnapType = 'none';
  });

  window.addEventListener('mouseup', () => {
    if (!isDown) return;
    isDown = false;
    wrap.style.scrollSnapType = 'x mandatory';
    const item = track.querySelector('.ugc-gallery__item');
    if (!item) return;
    const itemW = item.offsetWidth + parseFloat(getComputedStyle(track).gap || 0);
    const index = Math.round(wrap.scrollLeft / itemW);
    wrap.scrollTo({ left: index * itemW, behavior: 'smooth' });
  });

  window.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - wrap.offsetLeft;
    wrap.scrollLeft = scrollLeft - (x - startX) * 1.4;
  });
})();
</script>

{% schema %}
{
  "name": "UGC Galerie Vidéos",
  "tag": "section",
  "class": "section-ugc-gallery",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Plus de 15 000 femmes l'ont adopté, et vous ?"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Vidéo UGC",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "URL de la vidéo (.mp4)",
          "info": "Contenu > Fichiers > copier l'URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de fallback"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Texte overlay (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Galerie Vidéos",
      "blocks": [
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" }
      ]
    }
  ]
}
{% endschema %}
