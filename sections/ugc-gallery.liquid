<section class="ugc-gallery" id="ugc-gallery-{{ section.id }}">
  <div class="ugc-gallery__header">
    <h2 class="ugc-gallery__title">{{ section.settings.title }}</h2>
  </div>

  <div class="ugc-gallery__track-wrap" id="ugc-track-{{ section.id }}">
    <div class="ugc-gallery__track">
      {%- for block in section.blocks -%}
        <div class="ugc-gallery__item" {{ block.shopify_attributes }}>
          <div class="ugc-gallery__media-wrapper">
            {%- if block.settings.video_url != blank -%}
              <video autoplay loop muted playsinline preload="auto" class="ugc-gallery__video">
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- elsif block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="ugc-gallery__image"
                loading="lazy"
                draggable="false"
              >
            {%- endif -%}

            {%- if block.settings.overlay_text != blank -%}
              <div class="ugc-gallery__overlay">
                <span class="ugc-gallery__overlay-text">{{ block.settings.overlay_text }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_dots -%}
    <div class="ugc-gallery__dots" id="ugc-dots-{{ section.id }}">
      {%- for block in section.blocks -%}
        <button class="ugc-gallery__dot {% if forloop.first %}is-active{% endif %}" aria-label="Slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<style>
  #ugc-gallery-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__title {
    text-align: center;
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 36px;
    line-height: 1.25;
  }

  /* ── Track wrapper : scroll snap container ── */
  #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap {
    overflow-x: scroll;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 24px;
    cursor: grab;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap:active {
    cursor: grabbing;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__track-wrap::-webkit-scrollbar {
    display: none;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__track {
    display: flex;
    gap: {{ section.settings.gap }}px;
    width: max-content;
    align-items: stretch;
  }

  /* ── Chaque item ── */
  #ugc-gallery-{{ section.id }} .ugc-gallery__item {
    scroll-snap-align: start;
    flex-shrink: 0;
    width: calc((100vw - 48px - ({{ section.settings.columns_desktop }} - 1) * {{ section.settings.gap }}px) / {{ section.settings.columns_desktop }});
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__media-wrapper {
    position: relative;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    background: #d9d0c7;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__video,
  #ugc-gallery-{{ section.id }} .ugc-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    draggable: false;
  }

  /* ── Overlay post-it ── */
  #ugc-gallery-{{ section.id }} .ugc-gallery__overlay {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    z-index: 2;
    pointer-events: none;
    width: 85%;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__overlay-text {
    display: inline-block;
    background: #ffffff;
    color: #1a1a1a;
    font-size: clamp(11px, 0.9vw, 14px);
    font-weight: 600;
    line-height: 1.35;
    padding: 8px 12px;
    border-radius: 6px;
    text-align: center;
    max-width: 100%;
    box-shadow: 1px 2px 8px rgba(0,0,0,0.2);
  }

  /* ── Dots ── */
  #ugc-gallery-{{ section.id }} .ugc-gallery__dots {
    display: flex;
    justify-content: center;
    gap: 7px;
    margin-top: 24px;
    padding: 0 24px;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s, transform 0.25s;
    flex-shrink: 0;
  }

  #ugc-gallery-{{ section.id }} .ugc-gallery__dot.is-active {
    background: {{ section.settings.dot_color }};
    transform: scale(1.35);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    #ugc-gallery-{{ section.id }} .ugc-gallery__item {
      width: calc((100vw - 48px - ({{ section.settings.columns_mobile }} - 1) * 12px) / {{ section.settings.columns_mobile }});
    }

    #ugc-gallery-{{ section.id }} .ugc-gallery__track {
      gap: 12px;
    }

    #ugc-gallery-{{ section.id }} .ugc-gallery__title {
      font-size: 22px;
      margin-bottom: 24px;
    }
  }
</style>

<script>
(function() {
  const section = document.getElementById('ugc-gallery-{{ section.id }}');
  if (!section) return;

  const wrap = section.querySelector('.ugc-gallery__track-wrap');
  const track = section.querySelector('.ugc-gallery__track');
  const dots = section.querySelectorAll('.ugc-gallery__dot');

  // ── Snap par dot ──
  function getItemWidth() {
    const item = track.querySelector('.ugc-gallery__item');
    if (!item) return 0;
    const gap = parseFloat(getComputedStyle(track).gap) || 0;
    return item.offsetWidth + gap;
  }

  function scrollToIndex(index) {
    wrap.scrollTo({ left: index * getItemWidth(), behavior: 'smooth' });
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => scrollToIndex(i));
  });

  // ── Mise à jour des dots au scroll ──
  function updateDots() {
    const itemW = getItemWidth();
    if (!itemW) return;
    const index = Math.round(wrap.scrollLeft / itemW);
    dots.forEach((d, i) => d.classList.toggle('is-active', i === index));
  }

  wrap.addEventListener('scroll', updateDots, { passive: true });

  // ── Mouse drag avec momentum ──
  let isDown = false;
  let startX = 0;
  let scrollLeft = 0;

  wrap.addEventListener('mousedown', e => {
    isDown = true;
    startX = e.pageX - wrap.offsetLeft;
    scrollLeft = wrap.scrollLeft;
    wrap.style.scrollSnapType = 'none';
  });

  window.addEventListener('mouseup', () => {
    if (!isDown) return;
    isDown = false;
    wrap.style.scrollSnapType = 'x mandatory';
    // Snap au plus proche
    const itemW = getItemWidth();
    const index = Math.round(wrap.scrollLeft / itemW);
    scrollToIndex(index);
  });

  window.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - wrap.offsetLeft;
    const walk = (x - startX) * 1.5;
    wrap.scrollLeft = scrollLeft - walk;
  });
})();
</script>

{% schema %}
{
  "name": "UGC Galerie Vidéos",
  "tag": "section",
  "class": "section-ugc-gallery",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Plus de 150 000 femmes l'ont adopté, et vous ?"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Vidéos visibles (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Vidéos visibles (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement entre vidéos",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Afficher les points de navigation",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Couleur dot actif",
      "default": "#e91e8c"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Vidéo UGC",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "URL de la vidéo (.mp4)",
          "info": "Contenu > Fichiers > copier l'URL"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de fallback"
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "Texte overlay (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Galerie Vidéos",
      "blocks": [
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" },
        { "type": "video_item" }
      ]
    }
  ]
}
{% endschema %}
