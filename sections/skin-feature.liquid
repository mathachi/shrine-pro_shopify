{% comment %}
  Section: Skin Deep Feature
  Layout: Desktop = 2 colonnes (texte gauche / vidéo droite), Mobile = empilé
{% endcomment %}

<section class="skin-feature" id="skin-feature-{{ section.id }}">
  <div class="skin-feature__container">

    <!-- Colonne texte -->
    <div class="skin-feature__text">
      <h2 class="skin-feature__title">
        {{ section.settings.title_before }}
        <span class="skin-feature__title--highlight">{{ section.settings.title_highlight }}</span>
      </h2>
      <p class="skin-feature__description">{{ section.settings.description }}</p>
    </div>

    <!-- Colonne vidéo -->
    <div class="skin-feature__media">
      <div class="skin-feature__video-wrapper">
        {%- if section.settings.video_url != blank -%}
          <video
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            class="skin-feature__video"
          >
            <source src="{{ section.settings.video_url }}" type="video/mp4">
          </video>
        {%- elsif section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | escape }}"
            class="skin-feature__image"
            loading="lazy"
            width="800"
          >
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  #skin-feature-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .skin-feature__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .skin-feature__text {
    flex: 1;
    max-width: 480px;
  }

  .skin-feature__title {
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 500;
    line-height: 1.25;
    color: {{ section.settings.title_color }};
    margin: 0 0 20px;
  }

  .skin-feature__title--highlight {
    color: {{ section.settings.highlight_color }};
    display: inline;
  }

  .skin-feature__description {
    font-size: clamp(13px, 1.1vw, 15px);
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    margin: 0;
    max-width: 420px;
  }

  .skin-feature__media {
    flex: 1;
    max-width: 540px;
  }

  .skin-feature__video-wrapper {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: #e8ddd4;
  }

  .skin-feature__video,
  .skin-feature__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .skin-feature__container {
      flex-direction: column;
      gap: 32px;
      padding: 0 16px;
    }

    .skin-feature__text,
    .skin-feature__media {
      max-width: 100%;
      width: 100%;
    }

    .skin-feature__title {
      font-size: 26px;
    }
  }
</style>

{% schema %}
{
  "name": "Skin Feature",
  "tag": "section",
  "class": "section-skin-feature",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "title_before",
      "label": "Titre (partie normale)",
      "default": "Raffermit et hydrate instantanément la peau grâce à des"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Titre (partie colorée)",
      "default": "nutriments naturels"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Contrairement aux crèmes et lotions qui restent en surface, notre huile pénètre en profondeur là où la ménopause attaque vraiment la peau grâce à sa texture fine et ses ingrédients 100% naturel."
    },
    {
      "type": "header",
      "content": "Média"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL de la vidéo (.mp4)",
      "info": "Copiez l'URL de votre vidéo uploadée dans les fichiers Shopify (Contenu > Fichiers)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fallback (si pas de vidéo)"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#3b2f1e"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Couleur accentuée",
      "default": "#c8956a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Skin Feature"
    }
  ]
}
{% endschema %}
